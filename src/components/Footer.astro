---
import { brand } from '../data/config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="247 Local Trades">
          <span class="footer-logo-mark">247</span>
          <span class="footer-logo-text">Local Trades</span>
        </a>
        <p class="footer-tagline">{brand.tagline}</p>
        <p class="footer-desc">Exclusive leads. No bidding wars. One verified contractor per job â for HVAC, plumbing, electrical, and roofing across Northwest Florida.</p>
        <div class="footer-badges">
          <span class="badge">ð Licensed &amp; Insured</span>
          <span class="badge">â Background Checked</span>
        </div>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/florida/pensacola/hvac">HVAC â Pensacola</a></li>
          <li><a href="/florida/gulf-breeze/hvac">HVAC â Gulf Breeze</a></li>
          <li><a href="/florida/pensacola/plumbing">Plumbing</a></li>
          <li><a href="/florida/pensacola/electrical">Electrical</a></li>
          <li><a href="/florida/pensacola/roofing">Roofing</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About 247LT</a></li>
          <li><a href="/contractors">For Contractors</a></li>
          <li><a href="/service">Request Service</a></li>
          <li><a href="/florida">Coverage Area</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href={`tel:${brand.phone.hvac.replace(/\D/g,'')}`}>HVAC: {brand.phone.hvac}</a></li>
          <li><a href={`tel:${brand.phone.plumbing.replace(/\D/g,'')}`}>Plumbing: {brand.phone.plumbing}</a></li>
          <li><a href={`tel:${brand.phone.electrical.replace(/\D/g,'')}`}>Electrical: {brand.phone.electrical}</a></li>
          <li><a href={`tel:${brand.phone.roofing.replace(/\D/g,'')}`}>Roofing: {brand.phone.roofing}</a></li>
