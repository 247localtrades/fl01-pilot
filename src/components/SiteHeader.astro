---
import { brand } from '../data/config';

interface Props {
  trade?: 'hvac' | 'plumbing' | 'electrical' | 'roofing';
  activePage?: string;
}

const { trade = 'hvac', activePage = '' } = Astro.props;
const phone = brand.phone[trade];
const phoneRaw = phone.replace(/\D/g, '');
---

<header class="site-header">
  <div class="utility-bar">
    <div class="utility-inner">
      <span>ð Licensed &amp; Insured</span>
      <span>â Background Checked</span>
      <span>â± 24/7 Live Answering</span>
    </div>
  </div>

  <div class="header-main">
    <div class="header-inner">
      <a href="/" class="logo-link" aria-label="247 Local Trades â Home">
        <div class="logo-mark">247</div>
        <div class="logo-text">
          <span class="logo-local">Local</span>
          <span class="logo-trades">Trades</span>
        </div>
      </a>

      <nav class="main-nav" aria-label="Main navigation">
        <a href="/" class:list={['nav-link', { active: activePage === 'home' }]}>Home</a>
        <a href="/about" class:list={['nav-link', { active: activePage === 'about' }]}>About</a>
        <a href="/contractors" class:list={['nav-link', { active: activePage === 'contractors' }]}>For Contractors</a>
        <a href="/florida" class:list={['nav-link', { active: activePage === 'florida' }]}>Coverage Area</a>
      </nav>

      <div class="header-cta">
        <a href="/service" class="btn-request">
          <span class="btn-icon">ð</span> Request Service
        </a>
        <a href={`tel:${phoneRaw}`} class="btn-call" aria-label={`Call ${phone}`}>
          <span class="btn-icon">ð</span>
          <span class="call-number">{phone}</span>
        </a>
      </div>

      <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false" id="mobile-toggle">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <a href="/" class="mobile-nav-link">Home</a>
      <a href="/about" class="mobile-nav-link">About</a>
      <a href="/contractors" class="mobile-nav-link">For Contractors</a>
      <a href="/florida" class="mobile-nav-link">Coverage Area</a>
    </nav>
    <div class="mobile-cta">
      <a href="/service" class="btn-request mobile-full">ð Request Service</a>
      <a href={`tel:${phoneRaw}`} class="btn-call-mobile">ð {phone}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--brand-dark);
    box-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }
  .utility-bar {
    background: var(--brand-dark-deep, #222831);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 6px 0;
  }
  .utility-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .utility-inner span {
    font-size: 11px;
    color: var(--brand-teal, #63D0CA);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .header-main { padding: 0; }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 24px;
    height: 64px;
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    font-size: 24px;
    font-weight: 900;
    color: var(--brand-teal, #63D0CA);
    letter-spacing: -1px;
    line-height: 1;
  }
  .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
  .logo-local {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .logo-trades {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .main-nav { display: flex; gap: 4px; margin-left: auto; }
  .nav-link {
    padding: 8px 14px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover, .nav-link.active { color: #fff; background: rgba(255,255,255,0.08); }
  .nav-link.active { color: var(--brand-teal, #63D0CA); }
  .header-cta { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .btn-request {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    background: var(--brand-orange, #F97316);
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    border-radius: 8px;
    transition: opacity 0.15s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-request:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-call {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    border: 1px solid rgba(99,208,202,0.4);
    color: var(--brand-teal, #63D0CA);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn-call:hover { border-color: var(--brand-teal, #63D0CA); background: rgba(99,208,202,0.08); }
  .mobile-menu-toggle { display: none; flex-direction: column; gap: 5px; padding: 8px; background: none; border: none; cursor: pointer; margin-left: auto; }
  .hamburger-line { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; }
  .mobile-menu { display: none; flex-direction: column; background: var(--brand-dark-mid, #333A46); border-top: 1px solid rgba(255,255,255,0.08); padding: 16px 24px 20px; gap: 4px; }
  .mobile-menu[aria-hidden="false"] { display: flex; }
  .mobile-nav { display: flex; flex-direction: column; gap: 2px; margin-bottom: 16px; }
  .mobile-nav-link { padding: 11px 12px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 15px; font-weight: 500; border-radius: 8px; }
  .mobile-cta { display: flex; flex-direction: column; gap: 10px; }
  .btn-call-mobile { display: block; text-align: center; padding: 11px; border: 1px solid rgba(99,208,202,0.4); color: var(--brand-teal, #63D0CA); text-decoration: none; font-size: 15px; font-weight: 600; border-radius: 8px; }
  @media (max-width: 768px) {
    .main-nav, .header-cta { display: none; }
    .mobile-menu-toggle { display: flex; }
  }
</style>

<script is:inline>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.getAttribute('aria-hidden') === 'false';
      menu.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  }
</script>
